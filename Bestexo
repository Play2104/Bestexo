local function doScamTP()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") and pingPosition then
        local originalPos = char.HumanoidRootPart.CFrame
        char:SetPrimaryPartCFrame(CFrame.new(pingPosition)) -- TP au ping
        task.wait(1) -- Attend 1 seconde
        char:SetPrimaryPartCFrame(originalPos) -- Retour
    end
end

