    label.Font = Enum.Font.SourceSansBold
end

-------------------------------------------------
-- LOGIQUE FLY & NOCLIP
-------------------------------------------------
local bodyVel, bodyGyro

local function updateFlyState()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    if flyEnabled then
        if not bodyVel then
            bodyVel = Instance.new("BodyVelocity", char.HumanoidRootPart)
            bodyVel.MaxForce = Vector3.new(1e6, 1e6, 1e6)
            bodyGyro = Instance.new("BodyGyro", char.HumanoidRootPart)
            bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        end
        char.Humanoid.PlatformStand = true
    else
        if bodyVel then bodyVel:Destroy() bodyVel = nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
        char.Humanoid.PlatformStand = false
    end
    flyBtn.Text = flyEnabled and "Fly : ON" or "Fly : OFF"
end

flyBtn.MouseButton1Click:Connect(function() flyEnabled = not flyEnabled updateFlyState() end)
quickFly.MouseButton1Click:Connect(function() flyEnabled = not flyEnabled updateFlyState() end)
noclipBtn.MouseButton1Click:Connect(function() noclipEnabled = not noclipEnabled noclipBtn.Text = noclipEnabled and "Noclip : ON" or "Noclip : OFF" end)
quickNoclip.MouseButton1Click:Connect(function() noclipEnabled = not noclipEnabled noclipBtn.Text = noclipEnabled and "Noclip : ON" or "Noclip : OFF" end)

-------------------------------------------------
-- RUNSERVICE (BOUCLE)
-------------------------------------------------
RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    if noclipEnabled then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end

    if flyEnabled and bodyVel and bodyGyro then
        local cam = workspace.CurrentCamera
        bodyVel.Velocity = (char.Humanoid.MoveDirection.Magnitude > 0) and (cam.CFrame.LookVector * flySpeed) or Vector3.new(0,0,0)
        bodyGyro.CFrame = cam.CFrame
    end
end)

